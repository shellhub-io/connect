{
  "name": "shellhub-desktop",
  "version": "1.0.0",
  "description": "An application designed to simplify and enhance the experience of connecting and managing remote devices via ShellHub",
  "main": "./out/main/index.js",
  "author": "ShellHub <contact@shellhub.io>(https://shellhub.io)",
  "homepage": "https://github.com/shellhub-io/desktop",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts,.vue --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:win": "npm run build && electron-builder --win --config",
    "build:mac": "npm run build && electron-builder --mac --config",
    "build:linux": "npm run build && electron-builder --linux --config"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@mdi/font": "^7.4.47",
    "@vuelidate/core": "^2.0.3",
    "@vuelidate/validators": "^2.0.4",
    "@vueuse/core": "^13.9.0",
    "axios": "^1.12.2",
    "electron-updater": "^6.6.2",
    "pinia": "^3.0.3",
    "sass": "^1.93.2",
    "vee-validate": "^4.15.1",
    "vue-router": "^4.5.1",
    "vuetify": "^3.10.5",
    "webfontloader": "^1.6.28",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^1.0.2",
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@rushstack/eslint-patch": "^1.10.4",
    "@types/node": "^22.10.5",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.1.3",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^4.0.1",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^9.32.0",
    "less": "^4.2.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vite": "^7.0.7",
    "vite-plugin-vuetify": "^2.0.4",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.0"
  }
}
